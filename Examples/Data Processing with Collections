def map_square(numbers: list) -> list:
    '''
    Square each number in the given list of integers.

    Arguments:
    numbers: list - List of integers.

    Return: list - List of squared integers.
    '''
    <los>...</los>
    <sol>return [x ** 2 for x in numbers]</sol>
    test = <los>...</los><sol>'test'</sol> #tests


def filter_even(numbers: list) -> list:
    '''
    Filter out all even numbers from the list of integers.

    Arguments:
    numbers: list - List of integers.

    Return: list - List containing only odd numbers.
    '''
    <los>...</los>
    <sol>return [x for x in numbers if x % 2 != 0]</sol>
    test = <los>...</los><sol>'test'</sol> #tests


def aggregation(numbers: list) -> tuple:
    '''
    Calculate the sum and average of the list of numbers.

    Arguments:
    numbers: list - List of numbers.

    Return: tuple - A tuple with sum and average.
    '''
    <los>...</los>
    <sol>total = sum(numbers)
    avg = total / len(numbers) if numbers else 0
    return total, avg</sol>
    test = <los>...</los><sol>'test'</sol> #tests


def sort_by_second_element(tuples: list) -> list:
    '''
    Sort a list of tuples based on the second element in each tuple.

    Arguments:
    tuples: list - List of tuples.

    Return: list - List of tuples sorted by the second element.
    '''
    <los>...</los>
    <sol>return sorted(tuples, key=lambda x: x[1])</sol>
    test = <los>...</los><sol>'test'</sol> #tests


def group_by_key(data: list, key: str) -> dict:
    '''
    Group a list of dictionaries by a specific key.

    Arguments:
    data: list - List of dictionaries.
    key: str - The key to group by.

    Return: dict - A dictionary where each key maps to a list of dictionaries.
    '''
    <los>...</los>
    <sol>from itertools import groupby
    return {k: list(v) for k, v in groupby(sorted(data, key=lambda x: x[key]), key=lambda x: x[key])}</sol>
    test = <los>...</los><sol>'test'</sol> #tests


def find_unique_elements(data: list) -> set:
    '''
    Find the unique elements in a list using a set.

    Arguments:
    data: list - List of elements.

    Return: set - Set of unique elements.
    '''
    <los>...</los>
    <sol>return set(data)</sol>
    test = <los>...</los><sol>'test'</sol> #tests
