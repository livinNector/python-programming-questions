    def map_square(numbers: list) -> list:
    return [x ** 2 for x in numbers]

def filter_odd(numbers: list) -> list:
    return [x for x in numbers if x % 2 != 0]

def aggregation(numbers: list) -> tuple:
    total = sum(numbers)
    avg = total / len(numbers) if numbers else 0
    return total, avg

def sort_by_second_element(tuples: list) -> list:
    return sorted(tuples, key=lambda x: x[1])

def group_by_key(data: list, key: str) -> dict:
    from collections import defaultdict
    result = defaultdict(list)
    for item in data:
        result[item[key]].append(item['value'])
    return result

def find_unique_elements(data: list) -> set:
    return set(data)

def process_input():
    N = int(input())  # number of operations
    for _ in range(N):
        operation = input().split()
        op_type = operation[0]
        data = list(map(int, operation[1:]))
        
        if op_type == "map":
            result = map_square(data)
            print(*result)
        elif op_type == "filter":
            result = filter_odd(data)
            print(*result)
        elif op_type == "aggregation":
            result = aggregation(data)
            print(*result)
        elif op_type == "sort":
            result = sort_by_second_element([(i, data[i]) for i in range(len(data))])
            print(*[t[1] for t in result])
        elif op_type == "group":
            result = group_by_key([{'category': operation[i], 'value': operation[i+1]} for i in range(1, len(operation), 2)], 'category')
            print(result)
        elif op_type == "unique":
            result = find_unique_elements(data)
            print(result)

# Call the function to process the input
process_input()
