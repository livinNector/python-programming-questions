# Solution Template

class Library:
    def __init__(self):
        self.books = {}  # Dictionary to store books and their count

    def add_book(self, book_name: str):
        '''
        Add a new book to the library.

        Arguments:
        book_name: str - Name of the book to add.
        '''
        if book_name in self.books:
            self.books[book_name] += 1
        else:
            self.books[book_name] = 1
        print(f"Book '{book_name}' added to the library.")

    def borrow_book(self, book_name: str):
        '''
        Borrow a book if available.

        Arguments:
        book_name: str - Name of the book to borrow.
        '''
        if book_name in self.books and self.books[book_name] > 0:
            self.books[book_name] -= 1
            print(f"You have successfully borrowed '{book_name}'.")
        else:
            print(f"Sorry, the book '{book_name}' is not available.")

    def return_book(self, book_name: str):
        '''
        Return a borrowed book.

        Arguments:
        book_name: str - Name of the book to return.
        '''
        if book_name in self.books:
            self.books[book_name] += 1
            print(f"Thank you for returning '{book_name}'.")
        else:
            print(f"The book '{book_name}' does not belong to this library.")

    def check_availability(self, book_name: str):
        '''
        Check if a book is available in the library.

        Arguments:
        book_name: str - Name of the book to check.
        '''
        if book_name in self.books and self.books[book_name] > 0:
            print(f"The book '{book_name}' is available.")
        else:
            print(f"The book '{book_name}' is not available.")


