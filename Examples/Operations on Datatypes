<template>
def sum_integers(a: int, b: int) -> int:
    """
    Add two integers and return the result.

    Arguments:
    a: int - first integer
    b: int - second integer

    Return: int - sum of a and b
    """
    return a + b

def sum_floats(a: float, b: float) -> float:
    """
    Add two floating point numbers and return the result.

    Arguments:
    a: float - first float
    b: float - second float

    Return: float - sum of a and b
    """
    return a + b

def concat_strings(a: str, b: str) -> str:
    """
    Concatenate two strings and return the result.

    Arguments:
    a: str - first string
    b: str - second string

    Return: str - concatenation of a and b
    """
    return a + b

def concat_lists(a: list, b: list) -> list:
    """
    Concatenate two lists and return the result.

    Arguments:
    a: list - first list
    b: list - second list

    Return: list - concatenation of a and b
    """
    return a + b

def merge_dicts(a: dict, b: dict) -> dict:
    """
    Merge two dictionaries and return the result.

    Arguments:
    a: dict - first dictionary
    b: dict - second dictionary

    Return: dict - merged dictionary
    """
    return {**a, **b}

def union_sets(a: set, b: set) -> set:
    """
    Union two sets and return the result.

    Arguments:
    a: set - first set
    b: set - second set

    Return: set - union of a and b
    """
    return a | b

